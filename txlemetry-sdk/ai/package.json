{
  "name": "@txlemetry/ai",
  "version": "8.3.0",
  "description": "Txlemetry LLM analytics \u2014 observability for OpenAI, Anthropic, Gemini, LangChain, Vercel AI and OpenTelemetry.",
  "license": "MIT",
  "homepage": "https://txlemetry.com",
  "keywords": [
    "txlemetry",
    "llm",
    "ai",
    "observability",
    "openai",
    "anthropic",
    "langchain"
